// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------------
// ENUMS
// ------------------------------------------------------------

enum Locale {
  EN
  ID
}

// ProjectCategory used to be an enum here. It is now a table (see the model of
// the same name below) so the studio can add, rename and remove categories from
// the dashboard without a code deploy.

enum ProjectStatus {
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  PLANNED
}

enum ServiceType {
  ARCHITECTURE_DESIGN
  INTERIOR_DESIGN
  LANDSCAPE_DESIGN
  PROJECT_MANAGEMENT
  OTHER
}

enum ProjectTypeInquiry {
  RESIDENTIAL
  HOSPITALITY
  COMMERCIAL
  LANDSCAPE
  INTERIOR
  OTHER
}

enum BudgetRange {
  UNDER_50K
  RANGE_50K_150K
  ABOVE_150K
  PREFER_NOT_TO_SAY
}

// Shared triage status for every contact submission
// (inquiry / partnership / career). Renamed from InquiryStatus
// because all three contact models reuse it.
enum SubmissionStatus {
  NEW
  REVIEWED
  QUOTED
  BOOKED
  ARCHIVED
}

enum PartnershipType {
  DEVELOPER_COLLABORATION
  VENDOR_SUPPLIER
  MEDIA_PRESS
  CO_DESIGN_PROJECT
  OTHER
}

enum ExperienceRange {
  YEARS_0_2
  YEARS_3_5
  YEARS_6_10
  ABOVE_10_YEARS
}

enum EmploymentType {
  FULL_TIME
  PART_TIME_FREELANCE
  CONTRACT
  INTERNSHIP
}

enum PositionLevel {
  ENTRY
  MID_SENIOR
  SENIOR
  ALL_LEVELS
}

// ------------------------------------------------------------
// PROJECT
// ------------------------------------------------------------

model Project {
  id          String    @id @default(uuid())
  featured    Boolean   @default(false)
  publishedAt DateTime? // null = draft; set = published (sitemap/public)

  categoryId String
  category   ProjectCategory @relation(fields: [categoryId], references: [id])

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  services          ServiceType[]
  yearStart         Int
  yearEnd           Int?
  client            String?
  siteArea          Float? // m2
  buildingArea      Float? // m2
  status            ProjectStatus   @default(COMPLETED)
  architect         String          @default("ORI Studio")
  generalContractor String?

  translations ProjectTranslation[]
  images       ProjectImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // PostgreSQL does not index foreign keys on its own, and both columns are
  // filtered on in the listings.
  @@index([categoryId])
  @@index([locationId])
  @@map("projects")
}

/// Studio-managed list of project sectors (Residential, Hospitality, …).
/// The relation is intentionally left at Prisma's default `Restrict`: a
/// category still attached to a project cannot be deleted, so a delete can
/// never silently orphan or blank out a project's sector.
model ProjectCategory {
  id   String @id @default(uuid())
  name String @unique
  /// Stable key for filter URLs, so renaming the label doesn't break links.
  slug String @unique

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_categories")
}

/// A place a project can sit in. One row per city — province and country are
/// repeated rather than normalised into their own tables, which keeps the admin
/// form to a single dropdown instead of three cascading ones.
model Location {
  id       String @id @default(uuid())
  city     String
  province String
  country  String
  /// "canggu-bali-indonesia"
  slug String @unique

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([city, province, country])
  @@map("locations")
}

model ProjectTranslation {
  id          String  @id @default(uuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  locale      Locale
  name        String
  slug        String
  description String? @db.Text
  /// Narrative shown under the "Philosophy" heading on the detail page.
  /// Per-locale like description, so it lives here rather than on Project.
  philosophy String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, locale])
  @@unique([slug, locale])
  @@index([slug])
  @@map("project_translations")
}

model ProjectImage {
  id        String           @id @default(uuid())
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  type      ProjectImageType
  order     Int              @default(0)

  createdAt DateTime @default(now())

  @@map("project_images")
}

enum ProjectImageType {
  HERO
  GALLERY
}

// ------------------------------------------------------------
// ARTICLE (JOURNAL)
// ------------------------------------------------------------

model Article {
  id          String    @id @default(uuid())
  featured    Boolean   @default(false)
  publishedAt DateTime?

  categoryId String
  category   ArticleCategory @relation(fields: [categoryId], references: [id])

  image    String
  imageAlt String?

  translations ArticleTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@map("articles")
}

/// Journal categories, managed from the dashboard. Kept separate from
/// ProjectCategory so an article category can never be attached to a project —
/// the database itself rules it out.
model ArticleCategory {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  articles Article[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("article_categories")
}

model ArticleTranslation {
  id        String  @id @default(uuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  locale    Locale
  title     String
  slug      String
  excerpt   String? @db.Text
  content   Json // Tiptap JSON output

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([articleId, locale])
  @@unique([slug, locale])
  @@index([slug])
  @@map("article_translations")
}

// ------------------------------------------------------------
// CONTACT — INQUIRY
// ------------------------------------------------------------

model ContactInquiry {
  id                String             @id @default(uuid())
  fullName          String
  email             String
  phoneNumber       String?
  status            SubmissionStatus   @default(NEW)
  serviceType       ServiceType
  serviceTypeOther  String?
  projectType       ProjectTypeInquiry
  projectTypeOther  String?
  estimatedLocation String?
  estimatedBudget   BudgetRange
  vision            String             @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_inquiries")
}

// ------------------------------------------------------------
// CONTACT — PARTNERSHIP
// ------------------------------------------------------------

model ContactPartnership {
  id               String           @id @default(uuid())
  companyName      String
  role             String?
  email            String
  phoneNumber      String?
  partnershipType  PartnershipType
  partnershipOther String?
  vision           String           @db.Text
  status           SubmissionStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_partnerships")
}

// ------------------------------------------------------------
// CONTACT — CAREER
// ------------------------------------------------------------

model ContactCareer {
  id                 String           @id @default(uuid())
  fullName           String
  email              String
  phoneNumber        String?
  openPositionId     String?
  openPosition       OpenPosition?    @relation(fields: [openPositionId], references: [id], onDelete: SetNull)
  positionOfInterest String // fallback free text if position removed later
  portfolioUrl       String // required — the form marks it mandatory
  linkedinUrl        String?
  yearsOfExperience  ExperienceRange
  cvUrl              String // uploaded PDF, max 5MB (validated at API layer)
  status             SubmissionStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_careers")
}

// ------------------------------------------------------------
// OPEN POSITIONS
// ------------------------------------------------------------

model OpenPosition {
  id          String         @id @default(uuid())
  title       String
  type        EmploymentType
  level       PositionLevel
  description String         @db.Text
  isActive    Boolean        @default(true)

  careerApplications ContactCareer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("open_positions")
}

// ------------------------------------------------------------
// USER (Auth)
// ------------------------------------------------------------

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     String @default("user") // admin | editor | user

  /// When the password last changed, truncated to the second.
  /// Sessions are stateless JWTs, so this is what revokes them: any token
  /// issued before this instant is rejected. Null means "never changed since
  /// the account was created", so every existing token stays valid.
  passwordChangedAt DateTime?

  created_at DateTime @default(now())

  @@map("users")
}
